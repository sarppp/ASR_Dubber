# Start by ignoring everything
/*

# Bring back the top-level items we care about
!/.gitignore
!/README.md
!/run_pipeline.py
!/pipeline_paths.py
!/pipeline_utils.py
!/Dockerfile
!/docker-compose.yml
!/.dockerignore
!/entrypoint.sh
!/data/
!/data/input/
!/data/output/
# Ignore large media files — don't commit videos/audio
data/**/*.mp4
data/**/*.mkv
data/**/*.avi
data/**/*.mov
data/**/*.webm
data/**/*.m4v
data/**/*.ts
data/**/*.mts
data/**/*.wmv
data/**/*.flv
data/**/*.wav
data/**/*.mp3
data/**/*.flac
data/**/*.m4a
data/**/*.aac
data/**/*.ogg
data/**/*.opus
!/nemo/
!/qwen3-tts/
!/translate-gemma/
!/whisper/

# Inside nemo/: ignore everything, then unignore the exact files
nemo/*
!nemo/nemo.py
!nemo/nemo_modal_app.py
!nemo/nemo_diarization_report.py
!nemo/canary_patch.py
!nemo/nemo_diarize.py
!nemo/nemo_model.py
!nemo/nemo_audio.py
!nemo/qwen3_asr.py
!nemo/.python-version
!nemo/pyproject.toml
!nemo/uv.lock

# Inside qwen3-tts/
qwen3-tts/*
!qwen3-tts/dub.py
!qwen3-tts/qwen_tts_worker.py
!qwen3-tts/dubber_modal.py
!qwen3-tts/dub_srt.py
!qwen3-tts/dub_audio.py
!qwen3-tts/.python-version
!qwen3-tts/pyproject.toml
!qwen3-tts/uv.lock

# Repeat for translate-gemma/
translate-gemma/*
!translate-gemma/clean_subs.py
!translate-gemma/translate.py
!translate-gemma/translate_diarize.py
!translate-gemma/translate_utils.py
!translate-gemma/.python-version
!translate-gemma/pyproject.toml
!translate-gemma/uv.lock

# Whisper
whisper/*
!whisper/detect_language.py
!whisper/whisper_local.py
!whisper/whisper_modal_asr.py
!whisper/.python-version
!whisper/pyproject.toml
!whisper/uv.lock